{
  "name": "Sound Stream Development Container",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "soundstream-dev",
  "workspaceFolder": "/home/${localEnv:USER}/workspace",
  "initializeCommand": "bash setEnv.sh",
  "shutdownAction": "stopCompose",
  "updateRemoteUserUID": false,
  "containerEnv": {
    "CC": "/usr/bin/clang-20",
    "CXX": "/usr/bin/clang++-20",
    "PATH": "/usr/local/bin:/usr/bin:/bin:/usr/local/sbin:/usr/sbin:/sbin"
  },
  "features": {},
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": false, 
        "[c]": {
          "editor.defaultFormatter": "xaver.clang-format",
          "editor.formatOnSave": true
        },
        "[cpp]": {
          "editor.defaultFormatter": "xaver.clang-format",
          "editor.formatOnSave": true
        },
        "clang-format.style": "file",
        "editor.rulers": [80],
        "cmake.configureOnOpen": true,
        "cmake.generator": "Ninja",
        "cmake.cmakePath": "/usr/bin/cmake",
        "C_Cpp.default.compilerPath": "/usr/bin/clang++-20",
        "cmake.configureSettings": {
          "CMAKE_C_COMPILER": "/usr/bin/clang-20",
          "CMAKE_CXX_COMPILER": "/usr/bin/clang++-20"
        },
        "C_Cpp.intelliSenseEngine": "disabled",
        "clangd.path": "/usr/bin/clangd-20",
        "clangd.arguments": [
          "--background-index",
          "--clang-tidy",
          "--completion-style=detailed",
          "--header-insertion=iwyu",
          "--compile-commands-dir=${workspaceFolder}/build"
        ],
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
        "testMate.cpp.test.executables": "**/{build,Build,BUILD}/**/*{Test,test,TEST}*",
        "testMate.cpp.log.logpanel": true,
        "testMate.cpp.discovery.loadOnStartup": true,
        "testMate.cpp.test.workingDirectory": "${absDirpath}",
        "coverage-gutters.coverageFileNames": [
          "coverage.lcov",
          "lcov.info",
          "coverage.info",
          "cov.xml",
          "coverage.xml"
        ],
        "coverage-gutters.showLineCoverage": true,
        "coverage-gutters.showRulerCoverage": true,
        "coverage-gutters.showGutterCoverage": true,
        "coverage-gutters.coverageBaseDir": "",
        "cppcheck-official.standard": "c++20",
        "cppcheck-official.arguments": "--language=c++"
      },
      "extensions": [
        "llvm-vs-code-extensions.vscode-clangd",
        "ms-vscode.cmake-tools",
        "vadimcn.vscode-lldb",
        "alefragnani.bookmarks",
        "xaver.clang-format",
        "streetsidesoftware.code-spell-checker",
        "bierner.markdown-preview-github-styles",
        "ryanluker.vscode-coverage-gutters",
        "CppcheckSolutionsAB.cppcheck-official",
        "openai.chatgpt",
        "theqtcompany.qt",
        "theqtcompany.qt-core",
        "theqtcompany.qt-qml",
        "theqtcompany.qt-cpp",
        "theqtcompany.qt-ui",
        "andreoneti.qml-formatter"
      ]
    }
  }
}
